{
  "name": "thome-server",
  "version": "2.0.0",
  "scripts": {
    "dev":     "ts-node-dev --respawn --transpile-only src/index.ts",
    "build":   "tsc",
    "start":   "node dist/index.js",
    "migrate": "ts-node src/db/migrate.ts",
    "seed":    "ts-node src/db/seed.ts"
  },
  "dependencies": {
    "express":             "^4.18.2",
    "cors":                "^2.8.5",
    "drizzle-orm":         "^0.29.3",
    "postgres":            "^3.4.3",
    "zod":                 "^3.22.4",
    "dotenv":              "^16.4.1",
    "helmet":              "^7.1.0",
    "express-rate-limit":  "^7.1.5",
    "bcryptjs":            "^2.4.3",
    "jsonwebtoken":        "^9.0.2",
    "google-auth-library": "^9.6.3",
    "uuid":                "^9.0.0"
  },
  "devDependencies": {
    "@types/express":        "^4.17.21",
    "@types/cors":           "^2.8.17",
    "@types/bcryptjs":       "^2.4.6",
    "@types/jsonwebtoken":   "^9.0.5",
    "@types/uuid":           "^9.0.7",
    "@types/node":           "^20.11.5",
    "typescript":            "^5.3.3",
    "ts-node-dev":           "^2.0.0",
    "ts-node":               "^10.9.2"
  }
}
